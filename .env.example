# MySQL Database Configuration
# These environment variables are used to establish connection with MySQL database
# Update these values with your actual database credentials
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=school_management
DB_PORT=3306

# Server Configuration
# PORT: Specifies which port the Express server should listen on
# NODE_ENV: Indicates the environment (development, production, staging, etc.)
PORT=3000
NODE_ENV=development

# CORS Configuration
# CORS_ORIGIN: Specifies which domains are allowed to access this API
# For development, use '*' to allow all origins. For production, specify exact domains
CORS_ORIGIN=*
